generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. ENUMS
// ==========================================

enum UserRole {
  STUDENT
  HEAD_OF_DEPARTMENT
  VICE_DEAN
  DEAN
  ADMIN
  COMMITTEE
}

enum ApplicationStatus {
  DRAFT
  PENDING_DEPT_HEAD
  PENDING_VICE_DEAN
  PENDING_DEAN
  PENDING_ADMIN
  PENDING_COMMITTEE
  APPROVED
  REJECTED
  NEEDS_EDIT
}

enum LogAction {
  SUBMITTED
  APPROVED
  REJECTED
  MODIFIED
  RETURNED
}

enum UserStatus {
  PENDING_ONBOARDING  // รอลงทะเบียน (กรอกข้อมูลยังไม่ครบ)
  PENDING_APPROVAL    // รอแอดมินตรวจสอบ
  ACTIVE              // ใช้งานได้
  REJECTED            // ไม่อนุมัติ
}

// ==========================================
// 2. MODELS (AUTH SUPPORTED)
// ==========================================

model User {
  id            String    @id @default(uuid()) 
  
  name          String?   @map("fullname") 
  email         String?   @unique
  emailVerified DateTime?
  image         String?   
  
  actualId      String?   @unique 
  tel           String?
  role          UserRole  @default(STUDENT)
  status        UserStatus @default(PENDING_ONBOARDING)

  // Direct campus link for higher level roles (e.g. Campus Admin)
  campusId      String?
  campus        Campus?   @relation(fields: [campusId], references: [id])

  facultyId     String?   
  faculty       Faculty?  @relation(fields: [facultyId], references: [id])

  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])

  applications  AwardApplication[]
  activityLogs  ApprovalLog[]
  
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(uuid())
  
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// 3. BUSINESS MODELS
// ==========================================

model Campus {
  id          String @id @default(uuid())
  campusName  String
  
  faculties   Faculty[]
  users       User[]
  periods     ApplicationPeriod[]
}

model ApplicationPeriod {
  id           String   @id @default(uuid())
  academicYear String   // e.g., "2566"
  semester     String   // "1", "2", "SUMMER"
  
  startDate    DateTime
  endDate      DateTime
  
  campusId     String
  campus       Campus   @relation(fields: [campusId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Faculty {
  id          String @id @default(uuid())
  facultyName String
  
  campusId    String
  campus      Campus @relation(fields: [campusId], references: [id])
  
  departments Department[]
  users       User[]
}

model Department {
  id        String @id @default(uuid())
  name      String 
  
  facultyId String
  faculty   Faculty @relation(fields: [facultyId], references: [id])
  
  users     User[]
}

model AwardApplication {
  id               String    @id @default(uuid())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  
  // Basic Info
  academicYear     String    // e.g. "2566"
  semester         String    // "1", "2"
  
  gpax             Float?
  
  // Student verification file
  transcriptFile   String?   
  
  // Status
  status        ApplicationStatus @default(DRAFT)
  voteCount     Int?      @default(0)

  // Relations
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  
  // Note: AwardType might be per WorkItem or per Application? 
  // Usually the whole application is for a specific type (e.g. Activity, Innovation). 
  // Let's keep it here if the whole submission must be 1 category.
  typeId        String
  awardType     AwardType @relation(fields: [typeId], references: [id])

  workItems     WorkItem[]
  approvalLogs  ApprovalLog[]
  
  // Constraint: One active application per term per user
  // If rejected, does this constraint block them? 
  // "If rejected, cannot submit again" -> Constraint is good.
  @@unique([userId, academicYear, semester])
}

model WorkItem {
  id               String    @id @default(uuid())
  
  title            String
  competitionName  String?
  organizer        String?
  awardDate        DateTime?
  level            String?   // e.g. "University", "National"
  rank             String?   // "Winner", "Runner-up"
  isTeam           Boolean   @default(false)
  teamName         String?
  
  // Files for this specific work
  attachments      Attachment[]
  
  applicationId    String
  application      AwardApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model Attachment {
  id              String @id @default(uuid())
  fileUrl         String
  fileName        String?
  
  workItemId      String
  workItem        WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
}

model AwardType {
  id              String   @id @default(uuid())
  awardName       String
  description     String?
  iconUrl         String?
  scheduleFileUrl String?
  criteria        String?
  tags            String[]

  applications    AwardApplication[]
}

model ApprovalLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  actorId   String
  actor     User     @relation(fields: [actorId], references: [id])

  applicationId String
  application   AwardApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  action  LogAction
  step    ApplicationStatus
  comment String?
}