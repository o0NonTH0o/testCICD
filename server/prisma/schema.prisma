generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. ENUMS
// ==========================================

enum UserRole {
  STUDENT
  HEAD_OF_DEPARTMENT
  VICE_DEAN
  DEAN
  ADMIN
  COMMITTEE
}

enum ApplicationStatus {
  DRAFT
  PENDING_DEPT_HEAD
  PENDING_VICE_DEAN
  PENDING_DEAN
  PENDING_ADMIN
  PENDING_COMMITTEE
  APPROVED
  REJECTED
  NEEDS_EDIT
}

enum LogAction {
  SUBMITTED
  APPROVED
  REJECTED
  MODIFIED
  RETURNED
}

enum UserStatus {
  PENDING_ONBOARDING  // รอลงทะเบียน (กรอกข้อมูลยังไม่ครบ)
  PENDING_APPROVAL    // รอแอดมินตรวจสอบ
  ACTIVE              // ใช้งานได้
  REJECTED            // ไม่อนุมัติ
}

// ==========================================
// 2. MODELS (AUTH SUPPORTED)
// ==========================================

model User {
  id            String    @id @default(uuid()) 
  
  name          String?   @map("fullname") 
  email         String?   @unique
  emailVerified DateTime?
  image         String?   
  
  actualId      String?   @unique 
  tel           String?
  role          UserRole  @default(STUDENT)
  status        UserStatus @default(PENDING_ONBOARDING)

  facultyId     String?   
  faculty       Faculty?  @relation(fields: [facultyId], references: [id])

  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])

  applications  AwardApplication[]
  activityLogs  ApprovalLog[]
  
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(uuid())
  
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// 3. BUSINESS MODELS
// ==========================================

model Campus {
  id          String @id @default(uuid())
  campusName  String
  
  faculties   Faculty[]
}

model Faculty {
  id          String @id @default(uuid())
  facultyName String
  
  campusId    String
  campus      Campus @relation(fields: [campusId], references: [id])
  
  departments Department[]
  users       User[]
}

model Department {
  id        String @id @default(uuid())
  name      String 
  
  facultyId String
  faculty   Faculty @relation(fields: [facultyId], references: [id])
  
  users     User[]
}

model AwardApplication {
  id               String    @id @default(uuid())
  voteCount        Int?      @default(0)
  awardWorkDate    DateTime?
  competition      String?
  teamName         String?
  awardWorkTitle   String?
  awards           String?
  organizer        String?
  activityType     String?
  competitionLevel String?
  age              Int?
  birthdate        DateTime?
  gpax             Float?
  advisor          String?
  year             Int?
  address          String?
  
  status ApplicationStatus @default(DRAFT)

  userId String
  typeId String

  user      User      @relation(fields: [userId], references: [id])
  awardType AwardType @relation(fields: [typeId], references: [id])

  fileLogs     FileLog[]
  approvalLogs ApprovalLog[]
}

model AwardType {
  id        String @id @default(uuid())
  awardName String

  applications AwardApplication[]
}

model FileLog {
  id              String @id @default(uuid())
  attachedFileUrl String

  applicationId   String
  application     AwardApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model ApprovalLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  actorId   String
  actor     User     @relation(fields: [actorId], references: [id])

  applicationId String
  application   AwardApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  action  LogAction
  step    ApplicationStatus
  comment String?
}